{
  "kind": "collectionType",
  "collectionName": "menu_items",
  "info": {
    "singularName": "menu-item",
    "pluralName": "menu-items",
    "displayName": "Menu Item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Category": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Appetisers",
        "Mains",
        "Desserts",
        "Drinks"
      ]
    },
    "Name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "Description": {
      "type": "text"
    },
    "Price": {
      "type": "decimal",
      "default": 0,
      "min": 0
    },
    "MenuImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "videos"
      ]
    }
  }
}
